{
  "name": "advanced-commit-linter",
  "version": "2.1.2",
  "description": "Lint commit messages based on policy",
  "main": "src/main.ts",
  "scripts": {
    "build": "esbuild ./src/main.ts --bundle --outdir=dist --platform=node --target=node24.0.0 --packages=bundle --format=esm --external:debug --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "format": "prettier --write '**/*.ts'",
    "format-check": "prettier --check '**/*.ts'",
    "test": "vitest run --coverage",
    "update-snapshots": "vitest run --update",
    "all": "yarn && yarn run build && yarn run format && yarn test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/redhat-plumbers-in-action/advanced-commit-linter.git"
  },
  "keywords": [
    "actions",
    "node",
    "linter",
    "commit-messages"
  ],
  "author": "jamacku@redhat.com",
  "type": "module",
  "packageManager": "yarn@4.14.1",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/github": "9.1.1",
    "@octokit/core": "7.0.6",
    "@octokit/plugin-throttling": "11.0.3",
    "@probot/octokit-plugin-config": "4.1.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@octokit/types": "16.0.0",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.5",
    "esbuild": "^0.28.0",
    "prettier": "3.8.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  }
}
